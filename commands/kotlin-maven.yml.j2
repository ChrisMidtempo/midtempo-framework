# Midtempo Framework Configuration File
#
# IMPORTANT: If you edit this file you **MUST** re-generate the framework for changes to take effect

# ═══════════════════════════════════════════════════════════════════════════
# 1. BASE CONFIG
# ═══════════════════════════════════════════════════════════════════════════

{{ base_config }}

# ═══════════════════════════════════════════════════════════════════════════
# 2. CORE COMMANDS
# ═══════════════════════════════════════════════════════════════════════════
# test, lint, typecheck commands MUST be available. The framework depends on them

commands:
  test:
    command: "mvn test"
    description: "Run all tests"
    category: "test"

  lint:
    command: "mvn ktlint:check"
    description: "Run linter for code quality"
    category: "lint"

  typecheck:
    command: "mvn compile -q"
    description: "Run type checker via compilation"
    category: "typecheck"


# ═══════════════════════════════════════════════════════════════════════════
# 3. VARIANTS - Test/Lint/Typecheck
# ═══════════════════════════════════════════════════════════════════════════
# Organised variants of core commands by purpose - add/amend as required

  # Testing variants
  test_summary:
    command: "mvn test -q"
    description: "Run tests with summary output (quiet mode for gate checks)"
    category: "test"

  test_coverage:
    command: "mvn test jacoco:report"
    description: "Run tests with JaCoCo coverage report"
    category: "test"

  test_unit:
    command: "mvn test -Dtest='**/unit/**/*Test'"
    description: "Run unit tests only"
    category: "test"

  test_integration:
    command: "mvn verify -DskipUnitTests"
    description: "Run integration tests only"
    category: "test"

  # Linting variants
  lint_fix:
    command: "mvn ktlint:format"
    description: "Auto-fix linting issues"
    category: "lint"

# ═══════════════════════════════════════════════════════════════════════════
# 4. FORMATTING
# ═══════════════════════════════════════════════════════════════════════════
# Code formatting tools - add/amend as required

  format:
    command: "mvn ktlint:format"
    description: "Format code with ktlint"
    category: "format"

  format_check:
    command: "mvn ktlint:check"
    description: "Check formatting without changes"
    category: "format"


