# Midtempo Framework Configuration File
#
# IMPORTANT: If you edit this file you **MUST** re-generate the framework for changes to take effect

# ═══════════════════════════════════════════════════════════════════════════
# 1. BASE CONFIG
# ═══════════════════════════════════════════════════════════════════════════

{{ base_config }}

# ═══════════════════════════════════════════════════════════════════════════
# 2. CORE COMMANDS
# ═══════════════════════════════════════════════════════════════════════════
# test, lint, typecheck commands MUST be available. The framework depends on them

commands:
  test:
    command: "mix test"
    description: "Run all tests"
    category: "test"

  lint:
    command: "mix credo"
    description: "Run linter for code quality"
    category: "lint"

  typecheck:
    command: "mix dialyzer"
    description: "Run type checker (requires Dialyxir)"
    category: "typecheck"


# ═══════════════════════════════════════════════════════════════════════════
# 3. VARIANTS - Test/Lint/Typecheck
# ═══════════════════════════════════════════════════════════════════════════
# Organised variants of core commands by purpose - add/amend as required

  # Testing variants
  test_summary:
    command: "mix test --formatter ExUnit.CLIFormatter"
    description: "Run tests with summary output (quiet mode for gate checks)"
    category: "test"

  test_coverage:
    command: "mix test --cover"
    description: "Run tests with coverage report"
    category: "test"

  test_unit:
    command: "mix test test/unit/"
    description: "Run unit tests only"
    category: "test"

  test_integration:
    command: "mix test test/integration/"
    description: "Run integration tests only"
    category: "test"

  # test_e2e:
  #   command: "mix test test/e2e/"
  #   description: "Run all E2E tests"
  #   category: "test"

  # Linting variants
  # Note: Credo does not support auto-fix; mix format is the closest equivalent
  lint_fix:
    command: "mix format"
    description: "Auto-fix formatting issues (Credo has no auto-fix)"
    category: "lint"

# ═══════════════════════════════════════════════════════════════════════════
# 4. FORMATTING
# ═══════════════════════════════════════════════════════════════════════════
# Code formatting tools - add/amend as required

  format:
    command: "mix format"
    description: "Format code with mix format"
    category: "format"

  format_check:
    command: "mix format --check-formatted"
    description: "Check formatting without changes"
    category: "format"


