# Midtempo Framework Configuration File
#
# IMPORTANT: If you edit this file you **MUST** re-generate the framework for changes to take effect

# ═══════════════════════════════════════════════════════════════════════════
# 1. BASE CONFIG
# ═══════════════════════════════════════════════════════════════════════════

{{ base_config }}

# ═══════════════════════════════════════════════════════════════════════════
# 2. CORE COMMANDS
# ═══════════════════════════════════════════════════════════════════════════
# test, lint, typecheck commands MUST be available. The framework depends on them

commands:
  test:  
    command: "pytest"
    description: "Run all tests"
    category: "test"

  lint:
    command: "ruff check scripts/ tests/"
    description: "Run linter for code quality"
    category: "lint"

  typecheck:
    command: "mypy scripts/ tests/"
    description: "Run type checker"
    category: "typecheck"


# ═══════════════════════════════════════════════════════════════════════════
# 3. VARIANTS - Test/Lint/Typecheck
# ═══════════════════════════════════════════════════════════════════════════
# Organised variants of core commands by purpose - add/amend as required

  # Testing variants
  test_summary:
    command: "pytest -q --tb=short"
    description: "Run tests with summary output (quiet mode for gate checks)"
    category: "test"

  test_coverage:
    command: "pytest -q --tb=short --cov --cov-report=term-missing"
    description: "Run tests with coverage report"
    category: "test"

  test_unit:
    command: "pytest tests/unit/"
    description: "Run unit tests only"
    category: "test"

  test_integration:
    command: "pytest tests/integration/"
    description: "Run integration tests only"
    category: "test"

  # test_e2e:
  #   command: "pytest tests/e2e/"
  #   description: "Run all E2E tests"
  #   category: "test"

  # Linting variants
  lint_fix:
    command: "ruff check --fix scripts/ tests/"
    description: "Auto-fix linting issues"
    category: "lint"

# ═══════════════════════════════════════════════════════════════════════════
# 4. FORMATTING
# ═══════════════════════════════════════════════════════════════════════════
# Code formatting tools - add/amend as required

  format:
    command: "black scripts/ tests/"
    description: "Format code with Black"
    category: "format"
  format_check:
    command: "black --check scripts/ tests/"
    description: "Check formatting without changes"
    category: "format"


