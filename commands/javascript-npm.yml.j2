# Midtempo Framework Configuration File
#
# IMPORTANT: If you edit this file you **MUST** re-generate the framework for changes to take effect

# ═══════════════════════════════════════════════════════════════════════════
# 1. BASE CONFIG
# ═══════════════════════════════════════════════════════════════════════════

{{ base_config }}

# ═══════════════════════════════════════════════════════════════════════════
# 2. CORE COMMANDS
# ═══════════════════════════════════════════════════════════════════════════
# test, lint, typecheck commands MUST be available. The framework depends on them

commands:
  test:
    command: "npm test"
    description: "Run all tests"
    category: "test"

  lint:
    command: "npm run lint"
    description: "Run linter for code quality"
    category: "lint"

  typecheck:
    command: "npm run typecheck"
    description: "Run static analysis"
    category: "typecheck"


# ═══════════════════════════════════════════════════════════════════════════
# 3. VARIANTS - Test/Lint/Typecheck
# ═══════════════════════════════════════════════════════════════════════════
# Organised variants of core commands by purpose - add/amend as required

  # Testing variants
  test_summary:
    command: "npm test -- --silent"
    description: "Run tests with summary output (quiet mode for gate checks)"
    category: "test"

  test_coverage:
    command: "npm run test:coverage -- --silent"
    description: "Run tests with coverage report"
    category: "test"

  test_unit:
    command: "npm run test:unit"
    description: "Run unit tests only"
    category: "test"

  test_integration:
    command: "npm run test:integration"
    description: "Run integration tests only"
    category: "test"

  # test_e2e:
  #   command: "npm run test:e2e"
  #   description: "Run all E2E tests"
  #   category: "test"

  # Linting variants
  lint_fix:
    command: "npm run lint:fix"
    description: "Auto-fix linting issues"
    category: "lint"

# ═══════════════════════════════════════════════════════════════════════════
# 4. FORMATTING
# ═══════════════════════════════════════════════════════════════════════════
# Code formatting tools - add/amend as required

  format:
    command: "npm run format"
    description: "Format code with Prettier"
    category: "format"

  format_check:
    command: "npm run format:check"
    description: "Check formatting without changes"
    category: "format"


