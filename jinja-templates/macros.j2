{# Macro: test_status_check

   Purpose: Conditionally checks test status via logfile or test commands
            Allows control over when to use logfile vs running tests directly

   Parameters:
     - check_logfile: Whether to check logfile if available (required, boolean)
     - ctx: SmartContext instance providing access to configuration (required)

   Example Usage:
     Call macro with SmartContext (passed as 'this' in templates):
       At start of phase: test_status_check(true, this)
       At end of phase: test_status_check(false, this)

   Output when check_logfile=true and logfile exists:
     **Check test status log file**
     ```bash
     tail -5 /path/to/test.log
     ```

   Output when check_logfile=false or logfile doesn't exist:
     **Check test status**
     ```bash
     npm run test:python    # Run all Python tests
     ```

   Note: Direct-run path prefers test_summary when defined, falls back to test.
   Macro uses SmartContext to resolve test commands internally via ctx.cmd().
#}
{% macro test_status_check(check_logfile, ctx) -%}
{% if check_logfile and ctx.repo.logfile is defined and ctx.repo.logfile %}
**Check test status using the log file**

```bash
tail -5 {{ ctx.repo.logfile }}
```
{% else %}
**Check test status**

```bash
{% if ctx.commands.test_summary is defined -%}
{{ ctx.cmd('test_summary') }}
{%- else -%}
{{ ctx.cmd('test') }}
{%- endif %}
```
{% endif %}
{%- endmacro %}

{# Macro: test_gate

   Purpose: Renders test command appropriate for gate checks (entry/exit gates)
            Prefers test_summary for quiet pass/fail output, falls back to test

   Parameters:
     - ctx: SmartContext instance providing access to configuration (required)

   Example:
     {{ test_gate(this) }}

   Output when test_summary defined:
     pytest --tb=short    # Summary — pass/fail + failures only

   Output when test_summary not defined:
     pytest    # Verbose — no summary command configured
#}
{% macro test_gate(ctx) -%}
{%- if ctx.commands.test_summary is defined %}
{{ ctx.cmd('test_summary') }}    # Summary — pass/fail + failures only
{%- else %}
{{ ctx.cmd('test') }}    # Verbose — no summary command configured
{%- endif %}
{%- endmacro %}

{# Macro: test_targeted

   Purpose: Renders test command with <test-file> placeholder for TDD single-file runs

   Parameters:
     - ctx: SmartContext instance providing access to configuration (required)
     - show_comment: Whether to show the inline comment (optional, default: true)

   Example:
     {{ test_targeted(this) }}
     {{ test_targeted(this, show_comment=false) }}

   Output:
     pytest <test-file>    # Verbose — single file for TDD loop
     pytest <test-file>
#}
{% macro test_targeted(ctx, show_comment=true) -%}
{{ ctx.cmd('test') }} <test-file>{% if show_comment %}    # Verbose — single file for TDD loop{% endif %}
{%- endmacro %}

{# Macro: test_coverage_report

   Purpose: Renders test command appropriate for coverage/metrics runs
            Prefers test_coverage for metrics output, falls back to test

   Parameters:
     - ctx: SmartContext instance providing access to configuration (required)

   Example:
     {{ test_coverage_report(this) }}

   Output when test_coverage defined:
     pytest --cov    # Coverage — metrics + pass/fail

   Output when test_coverage not defined:
     pytest    # Verbose — no coverage command configured
#}
{% macro test_coverage_report(ctx) -%}
{%- if ctx.commands.test_coverage is defined %}
{{ ctx.cmd('test_coverage') }}    # Coverage — metrics + pass/fail
{%- else %}
{{ ctx.cmd('test') }}    # Verbose — no coverage command configured
{%- endif %}
{%- endmacro %}

{# Macro: command_block

   Purpose: Generate formatted command display block for a category

   Parameters:
     - ctx: SmartContext instance (required)
     - category: Command category name (required)
     - title: Display title (optional, defaults to formatted category name)
     - show_primary: Whether to show primary command before list (optional, default: true)
     - show_comments: Whether to show description comments (optional, default: true)

   Example:
     {{ command_block(this, 'test') }}
     {{ command_block(this, 'lint', title='Linting', show_primary=false) }}

   Output:
     #### Testing
     `npm run test`    # Run all test
     `npm run test:unit`    # Run unit tests
#}
{% macro command_block(ctx, category, title=none, show_primary=false, show_comments=true) -%}
{% set display_title = title if title else category|replace('_', ' ')|title %}
#### {{ display_title }}
```bash
{% if show_primary -%}
{{ ctx.cmd(category) }}    # Run all {{ category }}
{% endif -%}
{% for key, cmd, desc in ctx.category(category) %}
{{ cmd }}{% if show_comments %}    # {{ desc if desc else key|replace('_', ' ')|title }}{% endif %}

{% endfor %}
```
{%- endmacro %}

{# Macro: entry_gate_reads

   Purpose: Generate complete entry gate read validation block with section count verification

   Parameters:
     - ctx: SmartContext instance (required)
     - rules: List of rule file names without .md extension (optional, default: [])
     - rules_sections: Dict mapping rule names to section counts (optional, default: {})
     - instructions: List of instruction keys to check conditionally (optional, default: [])
     - instructions_sections: Dict mapping instruction keys to section counts (optional, default: {})
    
   Example:
     {{ entry_gate_reads(this,
          rules=['writing', 'testing'],
          rules_sections={'writing': 5, 'testing': 7},
          instructions=['purpose', 'architecture', 'db'],
          instructions_sections={'purpose': 8}) }}
          

   Output:
     VERIFY-COMPLETE-READ for EVERY file below:
       CHECK the last line says "END OF DOCUMENT"
       IF CHECK fails → Re-read from offset until true end

     READ ALL of `/midtempo-framework/rules/writing.md` → before proceeding
     READ ALL of `/midtempo-framework/instructions/purpose.md` → before proceeding
#}
{% macro entry_gate_reads(ctx, rules=[], rules_sections={}, instructions=[], instructions_sections={}) -%}
{{ verify_complete_read_header() }}
{% for page in rules %}
{{ read_file('/midtempo-framework/rules/' ~ page ~ '.md', 'before proceeding', rules_sections.get(page)) }}
{% endfor %}
{% for page_key in instructions %}
{% if page_key in ctx['instructions'] %}
{{ read_file('/midtempo-framework/instructions/' ~ ctx['instructions'][page_key].page, 'before proceeding', instructions_sections.get(page_key)) }}
{% endif %}
{% endfor %}
{%- endmacro %}

{# Macro: end_of_file

   Purpose: Creates a clear end-of-file marker for verification that file was fully read

   Parameters:
     - total_sections: Optional section count for verification (default: none)
     - file_purpose: Optional brief description of file purpose (default: none)

   Example:
     {{ end_of_file(total_sections=7, file_purpose='Agent rules and workflow') }}

   Output:
     ---
     **END OF DOCUMENT:** Total sections: 7 | Purpose: Agent rules and workflow

#}
{% macro end_of_file(total_sections=none, file_purpose=none) -%}
---
**END OF DOCUMENT:**{% if total_sections %} Total sections: {{ total_sections }}{% endif %}{% if file_purpose %}{% if total_sections %} |{% endif %} Purpose: {{ file_purpose }}{% endif %}
{%- endmacro %}

{# Macro: verify_compliance_gates

   Purpose: Generates conditional STOP blocks for instruction doc compliance gate verification at exit gates.
            Exit-side counterpart to require_instructions_read.

   Parameters:
     - gates: List of tuples (instruction_key, scope_description) (required)
     - instructions_dict: The instructions namespace/dict from context (required)

   Example:
     {{ verify_compliance_gates([('architecture', 'architecture'), ('error-handling', 'error handling')], instructions) }}

   Output:
     IF delivery scope touches architecture AND '/midtempo-framework/instructions/architecture.md "Compliance Gates"' not verified
       → STOP. "Verify all architecture compliance gates before proceeding."

     [repeated for each instruction doc present in config]
#}
{% macro verify_compliance_gates(gates, instructions_dict) -%}
{% for key, scope_desc in gates %}
{% if key in instructions_dict %}
IF delivery scope touches {{ scope_desc }} AND '/midtempo-framework/instructions/{{ instructions_dict[key].page }} "Compliance Gates"' not verified
  → STOP. "Verify all {{ key }} compliance gates before proceeding."
{% endif %}
{% endfor %}
{%- endmacro %}

