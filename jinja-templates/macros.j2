{# 
   GLOBAL MACROS FOR AGENTIC FRAMEWORK
   

   This file contains reusable macros that are automatically
   available in all templates without needing to import.

   Usage in templates:
   {{ read_file('/path/to/file.md', 'for understanding X') }}

    #}

{# Macro: read_file

   Purpose: Renders a single READ line for the agent. Verification is handled
            by verify_complete_read_header() in composite macros.

   Parameters:
     - path: File path to read (required)
     - context: Optional context string explaining why the file is being read
     - expected_sections: Retained for API compatibility (unused)

   Example:
     {{ read_file('/midtempo-framework/rules/writing.md', 'to understand writing conventions') }}

   Output:
     READ ALL of `/midtempo-framework/rules/writing.md` → to understand writing conventions
#}

{% macro read_file(path, context="", expected_sections=none) -%}
READ ALL of `{{ path }}`
{%- if context %} → {{ context }}{% endif %}
{% endmacro %}

{# Macro: verify_complete_read_header

   Purpose: Emits a single shared verification header for a block of file reads.
            Use once before a list of read_file calls instead of per-file verification.

   Example:
     {{ verify_complete_read_header() }}
     {{ read_file('/path/a.md', 'context') }}
     {{ read_file('/path/b.md', 'context') }}

   Output:
     VERIFY-COMPLETE-READ for EVERY file below:
       CHECK the last line says "END OF DOCUMENT"
       IF CHECK fails → Re-read from offset until true end
#}
{% macro verify_complete_read_header() -%}
VERIFY-COMPLETE-READ for EVERY file below:
  CHECK the last line says "END OF DOCUMENT"
  IF CHECK fails → Re-read from offset until true end
{% endmacro %}

{# Macro: completion_box

   Purpose: Creates a bordered completion box with centred title

   Parameters:
     - title: Title text to display in the box (required)

   Example:
     {{ completion_box('DESIGN COMPLETE: [FEATURE-NAME]') }}

   Output:
     <hr />
                             DESIGN COMPLETE: [FEATURE-NAME]
     
     <hr />
#}
{% macro completion_box(title) -%}
---
{{ title | center(79) }}

---
{%- endmacro %}

{# Macro: require_rules_read

   Purpose: Generates read instructions for multiple rules files with verification

   Parameters:
     - pages: List of rule file names (without .md extension) (required)

   Example:
     {{ require_rules_read(['writing', 'testing', 'tdd']) }}

   Output:
     VERIFY-COMPLETE-READ for EVERY file below:
       CHECK the last line says "END OF DOCUMENT"
       IF CHECK fails → Re-read from offset until true end

     READ ALL of `/midtempo-framework/rules/writing.md` → before proceeding
     READ ALL of `/midtempo-framework/rules/testing.md` → before proceeding
#}
{% macro require_rules_read(pages, sections) -%}
{{ verify_complete_read_header() }}
{% for page in pages %}
{{ read_file('/midtempo-framework/rules/' ~ page ~ '.md', 'before proceeding', sections) }}
{% endfor %}
{%- endmacro %}

{# Macro: require_instructions_read

   Purpose: Generates read instructions for multiple instruction files with verification
            Only includes instructions that exist in the config

   Parameters:
     - pages: List of instruction keys to check (required)
     - instructions_dict: The instructions namespace/dict from context (required)
     - sections: Optional dict mapping instruction keys to section counts (default: {})

   Example:
     {{ require_instructions_read(['purpose', 'architecture', 'db'], instructions, {'purpose': 8}) }}

   Output:
     VERIFY-COMPLETE-READ for EVERY file below:
       CHECK the last line says "END OF DOCUMENT"
       IF CHECK fails → Re-read from offset until true end

     READ ALL of `/midtempo-framework/instructions/purpose.md` → before proceeding
     READ ALL of `/midtempo-framework/instructions/architecture.md` → before proceeding
#}
{% macro require_instructions_read(pages, instructions_dict, sections={}) -%}
{{ verify_complete_read_header() }}
{% for page_key in pages %}
{% if page_key in instructions_dict %}
{{ read_file('/midtempo-framework/instructions/' ~ instructions_dict[page_key].page, 'before proceeding', sections.get(page_key)) }}
{% endif %}
{% endfor %}
{%- endmacro %}


{# Macro: conditional_ui_reads

   Purpose: Generates read instructions for UI-specific files when hasUI capability is true

   Parameters:
     - caps: The capabilities dict from context (required)
     - instructions_dict: The instructions namespace/dict from context (required)
     - include_new_page: Whether to include new-page instruction (optional, default: true)

   Example:
     {{ conditional_ui_reads(capabilities, instructions) }}
     {{ conditional_ui_reads(capabilities, instructions, include_new_page=false) }}

   Output:
     [Only when hasUI=true:]
     IF the current task involves UI
     READ ALL of `/midtempo-framework/instructions/frontend-design.md` → for UI component patterns
     READ ALL of `/midtempo-framework/instructions/style-guide.md` → for styling conventions

     [if include_new_page=true and new-page instruction exists:]
     IF the current task includes a new page/screen
     READ ALL of `/midtempo-framework/instructions/new-page.md` → for page wiring instructions
#}
{% macro conditional_ui_reads(caps, instructions_dict, include_new_page=true) -%}
{% if caps.hasUI -%}
{% if 'frontend-design' in instructions_dict -%}
IF the current task involves UI
{{ read_file('/midtempo-framework/instructions/' ~ instructions_dict['frontend-design'].page, 'for UI component patterns') }}
{% endif -%}
{% if 'style-guide' in instructions_dict -%}
{{ read_file('/midtempo-framework/instructions/' ~ instructions_dict['style-guide'].page, 'for styling conventions') }}
{% endif -%}
{% if include_new_page and 'new-page' in instructions_dict %}

IF the current task includes a new page/screen
{{ read_file('/midtempo-framework/instructions/' ~ instructions_dict['new-page'].page, 'for page wiring instructions') }}
{% endif -%}
{% endif -%}
{%- endmacro %}

{# Macro: conditional_db_reads

   Purpose: Generates read instructions for database-specific files when hasDB capability is true

   Parameters:
     - caps: The capabilities dict from context (required)
     - instructions_dict: The instructions namespace/dict from context (required)

   Example:
